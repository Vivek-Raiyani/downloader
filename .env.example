# General Settings
DOWNLOAD_DIR=downloads
S3_ENABLED=false

# AWS S3 Settings (Required if S3_ENABLED=true)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET_NAME=your_bucket_name
S3_REGION=us-east-1

# API Settings
DEBUG=true
PORT=8000

# Cleanup Settings (in seconds, 3600 = 1 hour)
CLEANUP_INTERVAL_SECONDS=60
FILE_RETENTION_SECONDS=60

# FFmpeg Path (Example: C:/ffmpeg/bin/ffmpeg.exe)
# Leave blank if ffmpeg is in your system PATH
FFMPEG_PATH=
